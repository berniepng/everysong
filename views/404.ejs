<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Not Found — EverySong</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,900;1,900&family=DM+Sans:wght@300;400&display=swap">
  <link rel="stylesheet" href="<%= base %>/public/css/main.css">
  <style>
    .not-found {
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
    }
    .nf-num {
      font-family: 'Playfair Display', serif;
      font-size: clamp(6rem, 20vw, 12rem);
      font-weight: 900;
      font-style: italic;
      color: var(--accent);
      opacity: 0.2;
      line-height: 1;
      margin-bottom: -1rem;
    }
    .nf-title {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      color: var(--fg);
      margin-bottom: 0.75rem;
    }
    .nf-sub {
      color: var(--fg-muted);
      font-size: 0.9rem;
      margin-bottom: 2rem;
    }
  </style>
</head>
<body>
  <nav class="site-nav">
    <a href="<%= base %>/" class="nav-brand"><span class="brand-every">Every</span><span class="brand-song">Song</span></a>
    <button class="theme-toggle" id="themeToggle"><span class="theme-icon">◐</span></button>
  </nav>
  <div class="not-found">
    <div class="nf-num">404</div>
    <h1 class="nf-title">Artist not found</h1>
    <p class="nf-sub">That artist doesn't exist in the archive yet.</p>
    <a href="<%= base %>/" class="btn-primary">← Back to Archive</a>
  </div>
  <script src="<%= base %>/public/js/theme.js"></script>
</body>
</html>
